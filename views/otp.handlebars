<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🔐 Access Code • Trueface</title>
    <style>
        /* MODERN CSS RESET */
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #8b5cf6;
            --accent: #06b6d4;
            --dark: #0f172a;
            --light: #f8fafc;
            --gray: #64748b;
            --success: #10b981;
            --glass: rgba(255, 255, 255, 0.1);
            --shadow-lg: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            color: var(--dark);
            line-height: 1.6;
        }
        
        /* GLASS MORPHISM CONTAINER */
        .email-container {
            max-width: 640px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        /* HERO HEADER WITH GRADIENT */
        .hero-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            padding: 60px 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .hero-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
            background-size: 30px 30px;
            animation: float 20s linear infinite;
        }
        
        @keyframes float {
            0% { transform: translate(0, 0) rotate(0deg); }
            100% { transform: translate(-30px, -30px) rotate(360deg); }
        }
        
        .logo {
            font-size: 32px;
            font-weight: 800;
            color: white;
            letter-spacing: -0.5px;
            margin-bottom: 16px;
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        
        .tagline {
            color: rgba(255, 255, 255, 0.9);
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        /* CONTENT AREA */
        .content {
            padding: 60px 40px;
        }
        
        /* ANIMATED OTP DISPLAY */
        .otp-display {
            background: linear-gradient(135deg, var(--light) 0%, #ffffff 100%);
            border-radius: 20px;
            padding: 40px;
            margin: 40px 0;
            text-align: center;
            position: relative;
            border: 2px solid rgba(99, 102, 241, 0.1);
            transition: all 0.3s ease;
        }
        
        .otp-display:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            border-color: var(--primary);
        }
        
        .otp-label {
            font-size: 14px;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 20px;
            font-weight: 600;
        }
        
        .otp-code {
            font-family: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
            font-size: 56px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 12px;
            margin: 20px 0;
            padding: 10px;
            position: relative;
            display: inline-block;
        }
        
        .otp-code::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 10%;
            width: 80%;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 2px;
        }
        
        /* EXPIRY TIMER */
        .expiry-timer {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: rgba(6, 182, 212, 0.1);
            padding: 16px 24px;
            border-radius: 50px;
            margin-top: 24px;
            font-size: 15px;
            font-weight: 600;
            color: var(--accent);
        }
        
        .timer-icon {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* INSTRUCTIONS GRID */
        .instructions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 24px;
            margin: 48px 0;
        }
        
        .instruction-card {
            background: var(--light);
            padding: 28px;
            border-radius: 16px;
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        
        .instruction-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
        }
        
        .card-icon {
            font-size: 32px;
            margin-bottom: 20px;
            color: var(--primary);
        }
        
        .card-title {
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--dark);
        }
        
        .card-text {
            color: var(--gray);
            font-size: 14px;
            line-height: 1.6;
        }
        
        /* SECURITY BADGE */
        .security-badge {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 20px;
            border-radius: 16px;
            margin: 40px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            font-weight: 600;
        }
        
        /* FOOTER */
        .footer {
            background: var(--dark);
            color: white;
            padding: 40px;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 32px;
            margin: 24px 0;
            flex-wrap: wrap;
        }
        
        .footer-link {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s ease;
        }
        
        .footer-link:hover {
            color: white;
        }
        
        .footer-note {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.5);
            margin-top: 24px;
            line-height: 1.6;
        }
        
        /* RESPONSIVE */
        @media (max-width: 640px) {
            .content, .hero-header {
                padding: 40px 24px;
            }
            
            .otp-code {
                font-size: 40px;
                letter-spacing: 8px;
            }
            
            .instructions-grid {
                grid-template-columns: 1fr;
            }
            
            .footer-links {
                flex-direction: column;
                gap: 16px;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="email-container">
        <!-- HERO HEADER -->
        <div class="hero-header">
            <div class="logo">
                <span class="logo-icon">👑</span>
                {appName}
            </div>
            <div class="tagline">Beauty Intelligence Platform</div>
        </div>
        
        <!-- MAIN CONTENT -->
        <div class="content">
            <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 16px; color: var(--dark);">
                Secure Access Code
            </h1>
            <p style="color: var(--gray); margin-bottom: 32px; font-size: 17px;">
                Your exclusive verification code is ready. Use it to securely access your account.
            </p>
            
            <!-- ANIMATED OTP DISPLAY -->
            <div class="otp-display">
                <div class="otp-label">Your Verification Code</div>
                <div class="otp-code">${{otp}}</div>
                <div class="expiry-timer">
                    <span class="timer-icon">⏱️</span>
                    Expires in <strong>{{time}}</strong>
                </div>
            </div>
            
            <!-- INSTRUCTIONS GRID -->
            <div class="instructions-grid">
                <div class="instruction-card">
                    <div class="card-icon">🔐</div>
                    <h3 class="card-title">Secure Entry</h3>
                    <p class="card-text">
                        Enter this code on the {{appName}} verification page to proceed with your password reset.
                    </p>
                </div>
                
                <div class="instruction-card">
                    <div class="card-icon">🚫</div>
                    <h3 class="card-title">Confidential</h3>
                    <p class="card-text">
                        Never share this code. Trueface staff will never ask for it via email, phone, or chat.
                    </p>
                </div>
                
                <div class="instruction-card">
                    <div class="card-icon">⚡</div>
                    <h3 class="card-title">One-Time Use</h3>
                    <p class="card-text">
                        This code is single-use and time-sensitive. Request a new one if it expires.
                    </p>
                </div>
                
                <div class="instruction-card">
                    <div class="card-icon">🛡️</div>
                    <h3 class="card-title">Account Safety</h3>
                    <p class="card-text">
                        If you didn't request this, secure your account immediately and contact our security team.
                    </p>
                </div>
            </div>
            
            <!-- SECURITY BADGE -->
            <div class="security-badge">
                <span>🔒</span>
                End-to-end encrypted • ISO 27001 compliant • GDPR ready
            </div>
            
            <!-- ACTION -->
            <div style="text-align: center; margin-top: 40px;">
                <a href="#" style="
                    display: inline-block;
                    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
                    color: white;
                    padding: 18px 42px;
                    border-radius: 50px;
                    text-decoration: none;
                    font-weight: 600;
                    font-size: 16px;
                    letter-spacing: 0.5px;
                    transition: all 0.3s ease;
                    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
                ">
                    Reset Password Now →
                </a>
            </div>
        </div>
        
        <!-- FOOTER -->
        <div class="footer">
            <div style="font-size: 14px; opacity: 0.8; margin-bottom: 16px;">
                Need help? Our team is here 24/7
            </div>
            <div class="footer-links">
                <a href="#" class="footer-link">Security Center</a>
                <a href="#" class="footer-link">Privacy Policy</a>
                <a href="#" class="footer-link">Trust & Safety</a>
                <a href="mailto:support@trueface.com" class="footer-link">Contact Support</a>
            </div>
            <div class="footer-note">
                © ${new Date().getFullYear()} Trueface Technologies. All rights reserved.<br>
                This message was sent to you because a password reset was requested for your account.<br>
                ID: ${Date.now().toString(36).toUpperCase()}-${otp}
            </div>
        </div>
    </div>
</body>
</html>